# LLM Provider Selection (openai, gemini, ollama)
# If left blank, provider is implicitly determined by which keys are provided below.
LLM_PROVIDER=

# API Keys for LLM Providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# OpenAI Compatible Server URL (Optional)
OPENAI_BASE_URL=

# Local Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# Default Model Setup (e.g. gpt-4o, gemini-2.5-pro, qwen2.5-coder:latest)
DEFAULT_MODEL=qwen2.5-coder:latest
