# ═════════════════════════════════════════════════════════════════════════════
# GitHub App Configuration (for webhook integration)
# ═════════════════════════════════════════════════════════════════════════════

# Your GitHub App ID (found on app settings page)
GITHUB_APP_ID=123456

# Path to private key PEM file (download from app settings → Private keys)
GITHUB_PRIVATE_KEY_PATH=backend/private-key.pem

# Webhook secret (set when creating the app)
GITHUB_WEBHOOK_SECRET=pentas_secret_123


# ═════════════════════════════════════════════════════════════════════════════
# LLM Provider Selection (openai, gemini, ollama)
# If left blank, provider is implicitly determined by which keys are provided below.
LLM_PROVIDER=


# API Keys for LLM Providers
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
GEMINI_API_KEY=

# OpenAI Compatible Server URL (Optional)
OPENAI_BASE_URL=

# Local Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# Default Models per Provider
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.5-pro
OLLAMA_MODEL=qwen2.5-coder:latest
